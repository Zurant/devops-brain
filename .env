# DevOps Brain 本地应用配置
# 本地用 poetry run uvicorn src.api.server:app --reload 启动，连接内网服务器基础设施。

# 环境模式：
# mock = 不真实调用 GitLab，适合本地自测
# prod = 真实调用 GitLab API
ENV=mock

# 内网基础设施服务器
INFRA_HOST=192.168.2.22

# PostgreSQL 业务库
DATABASE_URL=postgresql+psycopg://root:123456@192.168.2.22:5432/devops_brain

# Redis
REDIS_URL=redis://192.168.2.22:6379/0

# LLM / new-api
NEW_API_BASE_URL=http://192.168.2.109:3000/v1
NEW_API_KEY=sk-sIHvyunZrnJ3AaJf12aZAzRZXL4iuTZ2r7wC4QIvoI8JGHGW
MODEL_NAME=deepseek-v4-flash

# GitLab
# ENV=mock 时不会真实调用 GitLab；切到 ENV=prod 前再改成真实地址和 token。
GITLAB_URL=https://gitlab.your-company.com
GITLAB_TOKEN=glpat-change-me

# Langfuse
# 先访问 http://192.168.2.22:3010 初始化 Langfuse，创建项目后把 public/secret key 填回来。
LANGFUSE_HOST=http://192.168.2.22:3010
LANGFUSE_PUBLIC_KEY=pk-lf-510d6cbe-65a2-44f6-b24d-1c2269633ff3
LANGFUSE_SECRET_KEY=sk-lf-c6218e4c-5d2a-4c98-9713-b4ed6180e2a3