# 这份配置用于本地启动 DevOps Brain，连接内网服务器上的 PostgreSQL / Redis / Langfuse。

ENV=prod

# 改成内网服务器 IP 或域名
INFRA_HOST=192.168.1.100

DATABASE_URL=postgresql+psycopg://devops_brain:change-me-postgres-password@192.168.1.100:5432/devops_brain
REDIS_URL=redis://192.168.1.100:6379/0

NEW_API_BASE_URL=https://your-internal-new-api.com/v1
NEW_API_KEY=sk-change-me
MODEL_NAME=gemini-3.5-flash

GITLAB_URL=https://gitlab.your-company.com
GITLAB_TOKEN=glpat-change-me

# 首次启动 Langfuse 后，在 http://服务器IP:3000 创建项目，再把 key 填回来。
LANGFUSE_HOST=http://192.168.1.100:3000
LANGFUSE_PUBLIC_KEY=pk-lf-change-me
LANGFUSE_SECRET_KEY=sk-lf-change-me
